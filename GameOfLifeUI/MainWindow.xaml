<Window x:Class="GameOfLifeUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game of Life" Height="650" Width="850">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#333">
            <Button Name="btnStep" Content="Next Generation" Click="btnStep_Click" Width="120" Margin="5"/>
            <Button Name="btnPlay" Content="Auto Play" Click="btnPlay_Click" Width="100" Margin="5"/>
            <Button Name="btnClear" Content="Clear Grid" Click="btnClear_Click" Width="100" Margin="5"/>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <Label Content="Name:" Foreground="White" VerticalAlignment="Center"/>
                <TextBox Name="txtPatternName" Width="120" Height="25" Margin="5" VerticalContentAlignment="Center" Text="DefaultPattern"/>
            </StackPanel>

            <Button Name="btnSave" Content="Save Pattern" Click="btnSave_Click" Width="100" Margin="5" Background="DarkGreen" Foreground="White"/>
            <Button Name="btnLoad" Content="Load Pattern" Click="btnLoad_Click" Width="100" Margin="5" Background="DarkBlue" Foreground="White"/>

            <TextBlock Text="Click grid to add cells!" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>

        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Canvas Name="GameCanvas" 
                    Background="DimGray" 
                    Width="600" 
                    Height="600" 
                    MouseLeftButtonDown="GameCanvas_MouseLeftButtonDown"/>
        </ScrollViewer>
    </DockPanel>
</Window>